# jobs.vision frontend local environment for Neon
# Copy to frontend/.env. CRA requires restart after changing REACT_APP_* values.

# Required for Neon Auth login/register/session flows.
REACT_APP_NEON_AUTH_URL=
# Optional alias supported by the client. Prefer REACT_APP_NEON_AUTH_URL.
REACT_APP_NEON_AUTH_BASE_URL=

# Backend API base URL. The app defaults to http://localhost:5000/api, but set it explicitly for local testing.
REACT_APP_API_URL=http://localhost:5000/api

# Required only for manual override submission UI.
REACT_APP_HCAPTCHA_SITE_KEY=

# Required only for Google Maps rendering on the jobs page.
REACT_APP_GOOGLE_MAPS_API_KEY=

# Legacy/unused in the active app after Neon Auth/DB cutover.
REACT_APP_API_BASE=
REACT_APP_DEV_MODE=
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE=
REACT_PUBLIC_SUPABASE_URL=
REACT_PUBLIC_SUPABASE_ANON_KEY=
