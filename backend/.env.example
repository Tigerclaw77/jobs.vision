# jobs.vision backend local environment for Neon
# Copy to backend/.env and fill only the values needed for the flow you are testing.

# Required to boot the backend with Neon Postgres.
DATABASE_URL=

# Required for protected API routes that verify Neon Auth JWTs.
NEON_AUTH_JWKS_URL=
# Optional aliases supported by the verifier. Prefer NEON_AUTH_JWKS_URL.
NEON_AUTH_JWKS_URI=
NEON_JWKS_URL=
# Optional stricter JWT validation.
NEON_AUTH_ISSUER=
NEON_AUTH_AUDIENCE=

# Local server and callback URLs.
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:5000

# Optional Postgres tuning.
PGPOOL_MAX=10
PGSSLMODE=
PGSSL=

# Required only for outbound email flows.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Required only for manual override hCaptcha verification.
HCAPTCHA_SECRET=

# Required only for Stripe webhook/billing tests.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SKIP_VERIFY=false

# Legacy/optional Supabase Storage only.
# Not used for Supabase database or Supabase auth.
# Needed only if testing manual override file attachments with the current storage implementation.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_ROLE=
